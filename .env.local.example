# Clerk (Create at clerk.com - Application: "HMU ATL")
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Neon Database
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# Stripe (Development mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MOCK=true

# Sentry — error tracking
# DSN is quasi-public (embedded in client bundles); fine to put here for local dev.
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# Org + project slugs are non-sensitive build-time inputs.
SENTRY_ORG=hmup
SENTRY_PROJECT=javascript-nextjs
# DO NOT put SENTRY_AUTH_TOKEN in this file. opennextjs bakes .env.local into
# the deployed Worker bundle (see memory secret_leak_2026_05_06.md). The auth
# token lives ONLY in GitHub Environment secrets for the build step. Leaving
# it unset locally is fine — sourcemap upload just gets skipped on dev builds.

# Feature Flags
NODE_ENV=development
