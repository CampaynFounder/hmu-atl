{
  "expo": {
    "name": "HMU ATL",
    "slug": "hmu-atl",
    "version": "1.0.2",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d7abd3c4-5870-469f-b719-6ac77527ec03",
      "fallbackToCacheTimeout": 0
    },
    "scheme": "hmuatl",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080808",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hmucashride",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HMU ATL uses your location to find nearby drivers and track rides.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HMU ATL uses your location in the background to track your active ride.",
        "NSCameraUsageDescription": "HMU ATL needs camera access to upload your driver intro video and profile photo.",
        "NSMicrophoneUsageDescription": "HMU ATL needs microphone access for in-app calls between drivers and riders.",
        "NSPhotoLibraryUsageDescription": "HMU ATL needs access to your photo library to upload your profile photo and intro video.",
        "NSPhotoLibraryAddUsageDescription": "HMU ATL needs permission to save photos to your library.",
        "NSFaceIDUsageDescription": "HMU ATL uses Face ID to protect your account.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.hmucashride",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#080808"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "./plugins/withCxxFlags",
      "expo-secure-store",
      "expo-video",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "ccacheEnabled": false
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HMU ATL uses your location to find nearby drivers and track active rides."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00E676",
          "sounds": []
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.hmucashride",
          "enableGooglePay": true
        }
      ],
      "expo-image",
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7abd3c4-5870-469f-b719-6ac77527ec03"
      }
    },
    "owner": "hmucashride"
  }
}
